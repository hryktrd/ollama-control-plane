<mxfile host="app.diagrams.net" modified="2026-04-27" version="24.0.0">
  <diagram name="ollama-control-plane" id="architecture">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Ollama Control Plane — アーキテクチャ" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- ===== CLIENT ZONE ===== -->
        <mxCell id="zone-client" value="クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=12;fontStyle=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="220" height="520" as="geometry" />
        </mxCell>

        <!-- Client: Python Script -->
        <mxCell id="client-py" value="🖥️ Python スクリプト&#xa;(chat.py / OpenAI SDK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Client: curl -->
        <mxCell id="client-curl" value="⌨️ curl / HTTP クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="260" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Client: Claude Code -->
        <mxCell id="client-claude" value="🤖 Claude Code&#xa;(将来対応予定)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="360" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Client: Other PC -->
        <mxCell id="client-other" value="💻 別PC / 別ネットワーク&#xa;からも接続可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="460" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- ===== CONTROLLER ZONE ===== -->
        <mxCell id="zone-controller" value="Controller Server（Ubuntu + Docker）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;fontStyle=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="340" y="100" width="520" height="520" as="geometry" />
        </mxCell>

        <!-- Nginx box -->
        <mxCell id="nginx" value="🔒 Nginx (ネイティブ)&#xa;TLS 終端 / リバースプロキシ&#xa;ocp.example.org:443&#xa;Let&#39;s Encrypt 証明書" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Controller FastAPI box -->
        <mxCell id="controller-app" value="⚙️ Controller (Docker)&#xa;FastAPI + SQLite&#xa;127.0.0.1:8200&#xa;&#xa;• /agents/register&#xa;• /agents/poll&#xa;• /jobs/{id}/result&#xa;• /v1/chat/completions&#xa;• /admin/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="380" y="310" width="200" height="230" as="geometry" />
        </mxCell>

        <!-- Job Queue -->
        <mxCell id="jobqueue" value="📋 Job Queue&#xa;(asyncio.Queue)&#xa;&#xa;ジョブ待機・配布&#xa;結果待ち合わせ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="630" y="310" width="180" height="120" as="geometry" />
        </mxCell>

        <!-- DB -->
        <mxCell id="db" value="🗄️ SQLite&#xa;エージェント登録情報&#xa;トークン管理&#xa;ジョブ履歴" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="460" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- ===== AGENT HOST ZONE ===== -->
        <mxCell id="zone-agent" value="Agent Host（Windows WSL2 + Docker）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=12;fontStyle=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="220" height="520" as="geometry" />
        </mxCell>

        <!-- Agent Host Docker -->
        <mxCell id="agent-docker" value="🐳 Agent Host (Docker)&#xa;&#xa;• Ollama モデル検出&#xa;• Controller ポーリング&#xa;• ジョブ受信・実行&#xa;• 結果送信&#xa;• JWT 自動更新&#xa;&#xa;30秒間隔ポーリング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="960" y="160" width="180" height="200" as="geometry" />
        </mxCell>

        <!-- Ollama -->
        <mxCell id="ollama" value="🦙 Ollama (WSL2 ホスト)&#xa;host.docker.internal:11434&#xa;OLLAMA_HOST=0.0.0.0&#xa;&#xa;qwen2.5-coder:14b&#xa;gemma3:12b 等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="400" width="180" height="120" as="geometry" />
        </mxCell>

        <!-- GPU -->
        <mxCell id="gpu" value="🎮 RTX GPU&#xa;(VRAM 16GB 等)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="560" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- ===== ARROWS ===== -->

        <!-- Clients → Nginx: HTTPS -->
        <mxCell id="e1" value="HTTPS&#xa;POST /v1/chat/completions&#xa;Bearer sk-proj-xxx" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontColor=#6c8ebf;fontSize=10;" edge="1" source="client-py" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="client-curl" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;" edge="1" source="client-claude" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="client-other" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Nginx → Controller -->
        <mxCell id="e5" value="http://127.0.0.1:8200&#xa;（内部通信のみ）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#82b366;fontSize=10;" edge="1" source="nginx" target="controller-app" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Controller ↔ JobQueue -->
        <mxCell id="e6" value="enqueue / dequeue" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;strokeWidth=1.5;fontColor=#b46504;fontSize=10;" edge="1" source="controller-app" target="jobqueue" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Controller → DB -->
        <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;strokeWidth=1.5;" edge="1" source="controller-app" target="db" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Agent ↔ Controller: HTTPS polling -->
        <mxCell id="e8" value="HTTPS ポーリング&#xa;POST /agents/poll&#xa;（30秒 long-poll）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=2;fontColor=#d79b00;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="agent-docker" target="controller-app" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Agent → Ollama -->
        <mxCell id="e9" value="localhost&#xa;/api/chat" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=2;fontColor=#d79b00;fontSize=10;" edge="1" source="agent-docker" target="ollama" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Ollama → GPU -->
        <mxCell id="e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;strokeWidth=1.5;" edge="1" source="ollama" target="gpu" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend-title" value="凡例" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;" vertex="1" parent="1">
